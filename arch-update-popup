def _find_aur_helper() -> str | None:
    """Return the first available AUR helper (paru or yay), or None."""
    for h in ("paru", "yay"):
        if shutil.which(h):
            return h
    return None


def get_pending_updates(aur_helper: str | None) -> list[dict]:
    updates: list[dict] = []

    # Official repo updates
    r = subprocess.run(["checkupdates"], capture_output=True, text=True)
    if r.returncode == 0:
        for line in r.stdout.strip().splitlines():
            parts = line.split()
            if len(parts) >= 4:
                updates.append({"name": parts[0], "old": parts[1], "new": parts[3], "repo": "official"})

    # AUR updates
    if aur_helper:
        r = subprocess.run([aur_helper, "-Qua"], capture_output=True, text=True)
        if r.returncode == 0:
            for line in r.stdout.strip().splitlines():
                parts = line.split()
                if len(parts) >= 4:
                    # Check for supply-chain attack on AUR packages
                    compromised, reasons = check_aur_supply_chain_attack(parts[0])
                    updates.append({
                        "name": parts[0], 
                        "old": parts[1], 
                        "new": parts[3], 
                        "repo": "aur",
                        "compromised": compromised,
                        "compromise_reasons": reasons
                    })

    return updates


def fetch_pacman_info(pkg: str) -> dict:
    """Fetch package info; falls back to local DB for AUR packages."""
    info: dict = {"desc": "", "repo": "", "url": ""}

    r = subprocess.run(["pacman", "-Si", pkg], capture_output=True, text=True)
    src = r.stdout if r.returncode == 0 else ""

    if not src:
        # AUR / manually-installed package — use local database
        r = subprocess.run(["pacman", "-Qi", pkg], capture_output=True, text=True)
        src = r.stdout
        info["repo"] = "aur"

    for line in src.splitlines():
        if line.startswith("Description"):
            info["desc"] = line.split(":", 1)[1].strip()
        elif line.startswith("Repository"):
            info["repo"] = line.split(":", 1)[1].strip()
        elif line.startswith("URL "):
            info["url"] = line.split(":", 1)[1].strip()

    return info


def fetch_aur_pkgbuild(pkg: str) -> str | None:
    """Fetch PKGBUILD from AUR for a package."""
    try:
        # Try AUR GitLab first
        data = _get(f"https://aur.archlinux.org/cgit/aur.git/plain/PKGBUILD?h={pkg}", accept="text/plain", timeout=5)
        return data.decode(errors="replace")
    except Exception:
        pass
    return None


def scan_pkgbuild_for_threats(pkgbuild: str) -> list[str]:
    """Scan PKGBUILD for suspicious patterns indicating supply-chain attack."""
    threats = []
    for pattern, desc in _SUSPICIOUS_PKGBUILD_PATTERNS:
        if re.search(pattern, pkgbuild):
            threats.append(desc)
    return threats


def check_aur_supply_chain_attack(pkg_name: str) -> tuple[bool, list[str]]:
    """
    Check if an AUR package is compromised in the 2024 supply-chain attack.
    Returns (is_compromised, list_of_reasons).
    """
    reasons = []
    
    # Check known compromised package list
    if pkg_name in AUR_COMPROMISED_PACKAGES:
        reasons.append(f"Package '{pkg_name}' is in the known compromised package list (~1,500 packages affected in 2024 AUR supply-chain attack)")
    
    # Scan PKGBUILD for suspicious patterns
    pkgbuild = fetch_aur_pkgbuild(pkg_name)
    if pkgbuild:
        threats = scan_pkgbuild_for_threats(pkgbuild)
        if threats:
            reasons.extend([f"PKGBUILD contains suspicious pattern: {t}" for t in threats])
    
    return (len(reasons) > 0, reasons)


# ── Background threads ─────────────────────────────────────────────────────────

class UpdateChecker(QThread):
    """Checks for pending updates off the main thread."""
    updates_found = pyqtSignal(list)
    no_updates    = pyqtSignal()

    def __init__(self, aur_helper: str | None) -> None:
        super().__init__()
        self._aur_helper = aur_helper

    def run(self) -> None:
        updates = get_pending_updates(self._aur_helper)
        if updates:
            self.updates_found.emit(updates)
        else:
            self.no_updates.emit()


class InfoFetcher(QThread):
    """Fetches description and release notes for each pending update."""
    row_ready = pyqtSignal(int, str, str, str)  # row, desc, notes, date

    def __init__(self, updates: list[dict]) -> None:
        super().__init__()
        self._updates = updates

    def run(self) -> None:
        for i, pkg in enumerate(self._updates):
            if self.isInterruptionRequested():
                return
            info = fetch_pacman_info(pkg["name"])
            desc = info["desc"] or "No description available"
            notes, date = get_whats_new(
                pkg["name"], pkg["new"], info["url"], info["repo"]
            )
            self.row_ready.emit(i, desc, notes, date)


class UpdateRunner(QThread):
    """Runs the package update and streams per-package install progress."""
    install_progress = pyqtSignal(int, int, str)  # current, total, pkg_name
    done             = pyqtSignal(bool, str)       # success, last output lines

    def __init__(self, aur_helper: str | None, packages: list[str] | None = None) -> None:
        super().__init__()
        self._askpass: str | None = None

        if aur_helper:
            fd, path = tempfile.mkstemp(suffix=".sh", prefix="arch-update-askpass-")
            with os.fdopen(fd, "w") as f:
                f.write(
                    '#!/bin/bash\n'
                    'kdialog --title "Arch Update" --password '
                    '"${1:-Enter sudo password to install updates:}" 2>/dev/null\n'
                )
            os.chmod(path, stat.S_IRWXU)
            self._askpass = path
            if packages:
                self._cmd = [aur_helper, "--sudoflags", "-A", "-S", *packages, "--noconfirm"]
            else:
                self._cmd = [aur_helper, "--sudoflags", "-A", "-Syu", "--noconfirm"]
        else:
            if packages:
                self._cmd = ["pkexec", "pacman", "-S", *packages, "--noconfirm"]
            else:
                self._cmd = ["pkexec", "pacman", "-Syu", "--noconfirm"]

    def run(self) -> None:
        env = os.environ.copy()
        if self._askpass:
            env["SUDO_ASKPASS"] = self._askpass

        # Use a pty so paru/pacman think they're writing to a terminal and
        # flush output per line rather than buffering to the pipe.
        master_fd, slave_fd = pty.openpty()
        try:
            proc = subprocess.Popen(
                self._cmd,
                stdout=slave_fd, stderr=slave_fd,
                stdin=subprocess.DEVNULL,
                env=env, close_fds=True,
            )
        except FileNotFoundError as e:
            os.close(master_fd)
            os.close(slave_fd)
            self._cleanup()
            self.done.emit(False, str(e))
            return

        os.close(slave_fd)  # parent doesn't need the slave end

        lines: list[str] = []
        buf = ""
        while True:
            try:
                ready, _, _ = select.select([master_fd], [], [], 0.05)
            except (OSError, ValueError):
                break
            if ready:
                try:
                    buf += os.read(master_fd, 4096).decode(errors="replace")
                except OSError:
                    break
                while "\n" in buf:
                    raw, buf = buf.split("\n", 1)
                    for fragment in raw.split("\r"):
                        fragment = _ANSI_RE.sub("", fragment).strip()
                        if not fragment:
                            continue
                        lines.append(fragment)
                        m = _INSTALL_RE.match(fragment)
                        if m:
                            self.install_progress.emit(
                                int(m.group(1)), int(m.group(2)), m.group(3)
                            )
            elif proc.poll() is not None:
                break

        try:
            os.close(master_fd)
        except OSError:
            pass

        proc.wait()
        self._cleanup()
        self.done.emit(proc.returncode == 0, "\n".join(lines[-20:]))

    def _cleanup(self) -> None:
        if self._askpass:
            try:
                os.unlink(self._askpass)
            except OSError:
                pass
            self._askpass = None


# ── Update window ──────────────────────────────────────────────────────────────

class UpdateWindow(QMainWindow):
    closed           = pyqtSignal()
    update_succeeded = pyqtSignal()

    C_PKG  = 0
    C_OLD  = 1
    C_NEW  = 2
    C_DATE = 3
    C_DESC = 4
    C_NEWS = 5

    def __init__(
        self,
        updates:     list[dict],
        cached_info: dict[int, tuple[str, str, str]],
        aur_helper:  str | None,
    ) -> None:
        super().__init__()
        self._updates    = updates
        self._aur_helper = aur_helper
        self._runner:    UpdateRunner | None = None
        self._updating   = False
        self._pkg_row: dict[str, int] = {pkg["name"]: i for i, pkg in enumerate(updates)}
        self._installing_row: int | None = None
        self._compromised = any(pkg.get("compromised") for pkg in updates)
        n = len(updates)

        self.setWindowTitle(f"Arch Update  —  {n} package{'s' if n != 1 else ''} available")
        self.setMinimumSize(1300, 640)

        root = QWidget()
        self.setCentralWidget(root)
        lay = QVBoxLayout(root)
        lay.setContentsMargins(14, 14, 14, 14)
        lay.setSpacing(10)

        # ── Compromised warning banner ──────────────────────────────────────────
        if self._compromised:
            comp_pkgs = [p for p in updates if p.get("compromised")]
            comp_names = "\n".join(
                f"  • {p['name']}: {'; '.join(p.get('compromise_reasons', ['unknown']))}"
                for p in comp_pkgs
            )
            warning = QLabel(_AUR_COMPROMISED_NOTICE.format(packages=comp_names))
            warning.setStyleSheet(
                "background-color:#5c1f1f; color:#ff9999; padding:12px;"
                " border-radius:6px; font-size:12px; font-weight:bold;"
            )
            warning.setWordWrap(True)
            lay.addWidget(warning)

        n_cached = sum(1 for i in range(n) if i in cached_info)
        self._hdr = QLabel()
        self._hdr.setStyleSheet("font-size: 13px;")
        self._set_idle_header(n_cached)
        lay.addWidget(self._hdr)

        # ── Table ──────────────────────────────────────────────────────────────
        self.table = QTableWidget(n, 6)
        self.table.setHorizontalHeaderLabels(
            ["Package", "Installed", "New Version", "Release Date", "Description", "What's New"]
        )
        self.table.setAlternatingRowColors(True)
        self.table.setWordWrap(True)
        self.table.setSelectionBehavior(QTableWidget.SelectionBehavior.SelectRows)
        self.table.verticalHeader().setVisible(False)
        self.table.setEditTriggers(QTableWidget.EditTrigger.NoEditTriggers)

        for i, pkg in enumerate(updates):
            self._cell(i, self.C_PKG, pkg["name"], bold=True)
            self._cell(i, self.C_OLD, pkg["old"],  muted=True)
            self._cell(i, self.C_NEW, pkg["new"],  color="#2ecc71")
            if i in cached_info:
                desc, notes, date = cached_info[i]
                self._cell(i, self.C_DATE, date or "–", muted=not date)
                self._cell(i, self.C_DESC, desc)
                self._cell(i, self.C_NEWS, notes)
            else:
                self._cell(i, self.C_DATE, "–",                       muted=True)
                self._cell(i, self.C_DESC, "Loading…",                 muted=True)
                self._cell(i, self.C_NEWS, "Fetching release notes…",  muted=True)
            if pkg.get("compromised"):
                color = QColor("#4a1515")
                for col in range(self.table.columnCount()):
                    item = self.table.item(i, col)
                    if item:
                        item.setBackground(color)

        h = self.table.horizontalHeader()
        h.setSectionResizeMode(self.C_PKG,  QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(self.C_OLD,  QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(self.C_NEW,  QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(self.C_DATE, QHeaderView.ResizeMode.ResizeToContents)
        h.setSectionResizeMode(self.C_DESC, QHeaderView.ResizeMode.Stretch)
        h.setSectionResizeMode(self.C_NEWS, QHeaderView.ResizeMode.Stretch)
        lay.addWidget(self.table)

        # ── Progress / status ──────────────────────────────────────────────────
        self._progress = QProgressBar()
        self._progress.setRange(0, n)
        self._progress.setValue(n_cached)
        self._progress.setFormat(
            "Release notes loaded  ✓" if n_cached >= n else "Loading…  %v / %m"
        )
        lay.addWidget(self._progress)

        self._status = QLabel("")
        self._status.setStyleSheet("font-style: italic; color: gray; font-size: 12px;")
        self._status.setWordWrap(True)
        lay.addWidget(self._status)

        # ── Buttons ────────────────────────────────────────────────────────────
        btn_row = QHBoxLayout()
        btn_row.addStretch()

        self._skip_btn = QPushButton("Skip for Now")
        self._skip_btn.setFixedHeight(38)
        self._skip_btn.setMinimumWidth(110)
        self._skip_btn.clicked.connect(self.close)
        btn_row.addWidget(self._skip_btn)

        self._update_btn = QPushButton("  Update All  ")
        self._update_btn.setFixedHeight(38)
        self._update_btn.setMinimumWidth(130)
        self._update_btn.setStyleSheet(
            "QPushButton { background-color:#3584e4; color:white; border-radius:5px;"
            " font-weight:bold; font-size:13px; padding:0 18px; }"
            "QPushButton:hover { background-color:#1c71d8; }"
            "QPushButton:disabled { background-color:#888; color:#ccc; }"
        )
        if self._compromised:
            safe_n = sum(1 for p in updates if not p.get("compromised"))
            self._update_btn.setText(f"  Update {safe_n} Safe Package{'s' if safe_n != 1 else ''}  ")
        self._update_btn.clicked.connect(self.start_update)
        btn_row.addWidget(self._update_btn)
        lay.addLayout(btn_row)

    # ── Helpers ────────────────────────────────────────────────────────────────

    def _set_idle_header(self, n_cached: int) -> None:
        n = len(self._updates)
        n_safe = sum(1 for p in self._updates if not p.get("compromised"))
        n_comp = n - n_safe
        suffix = " &nbsp;·&nbsp; fetching release notes…" if n_cached < n else ""
        if n_comp:
            self._hdr.setText(
                f"<b>{n_safe} safe</b> ready to install &nbsp;·&nbsp; "
                f"<b>{n_comp} compromised</b> — skipped{suffix}"
            )
        else:
            self._hdr.setText(
                f"<b>{n} package{'s' if n != 1 else ''}</b> ready to install{suffix}"
            )

    def _cell(self, row: int, col: int, text: str,
              bold: bool = False, color: str = "", muted: bool = False) -> None:
        item = QTableWidgetItem(text)
        item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
        if bold:
            f = item.font(); f.setBold(True); item.setFont(f)
        if color:
            item.setForeground(QColor(color))
        elif muted:
            item.setForeground(QColor("#888888"))
        self.table.setItem(row, col, item)

    def _set_row_install_state(self, row: int, state: str) -> None:
        if state == "installing":
            bg = QColor("#2a5f9e")
        elif state == "done":
            bg = QColor("#27622a")
        else:
            for col in range(self.table.columnCount()):
                item = self.table.item(row, col)
                if item:
                    item.setData(Qt.ItemDataRole.BackgroundRole, None)
            return
        for col in range(self.table.columnCount()):
            item = self.table.item(row, col)
            if item:
                item.setBackground(bg)

    # ── Called by TrayApp as background data arrives ───────────────────────────

    def on_info_ready(self, row: int, desc: str, notes: str, date: str) -> None:
        self._cell(row, self.C_DESC, desc)
        self._cell(row, self.C_NEWS, notes)
        self._cell(row, self.C_DATE, date or "–", muted=not date)
        self.table.resizeRowToContents(row)
        if not self._updating:
            self._progress.setValue(self._progress.value() + 1)

    def on_fetch_done(self) -> None:
        if not self._updating:
            self._set_idle_header(len(self._updates))
            self._progress.setFormat("Release notes loaded  ✓")

    # ── Update flow ────────────────────────────────────────────────────────────

    def start_update(self) -> None:
        self._updating = True
        self._update_btn.setEnabled(False)
        self._skip_btn.setEnabled(False)

        safe_pkgs = [p for p in self._updates if not p.get("compromised")]
        comp_pkgs = [p for p in self._updates if p.get("compromised")]
        safe_names = [p["name"] for p in safe_pkgs]

        n = len(safe_pkgs)
        self._hdr.setText(f"<b>0</b> installed &nbsp;·&nbsp; <b>{n}</b> remaining")
        msg = "Waiting for authentication — a password dialog should appear…"
        if comp_pkgs:
            skipped = ", ".join(p["name"] for p in comp_pkgs)
            msg = f"Skipping compromised: {skipped}. {msg}"
        self._status.setText(msg)
        self._progress.setRange(0, 0)
        self._progress.setFormat("")

        self._runner = UpdateRunner(self._aur_helper, safe_names if self._compromised else None)
        self._runner.install_progress.connect(self._on_install_progress)
        self._runner.done.connect(self._on_update_done)
        self._runner.start()

    def _on_install_progress(self, current: int, total: int, pkg: str) -> None:
        if self._progress.maximum() == 0:
            self._progress.setRange(0, total)   # switch away from indeterminate
        self._progress.setValue(current)
        remaining = total - current
        self._hdr.setText(
            f"<b>{current}</b> installed &nbsp;·&nbsp; <b>{remaining}</b> remaining"
        )
        self._status.setText(f"Installing {pkg}…")
        if self._installing_row is not None:
            self._set_row_install_state(self._installing_row, "done")
        self._installing_row = self._pkg_row.get(pkg)
        if self._installing_row is not None:
            self._set_row_install_state(self._installing_row, "installing")
            self.table.scrollToItem(self.table.item(self._installing_row, self.C_PKG))

    def _on_update_done(self, success: bool, output: str) -> None:
        n_total = len(self._updates)
        n_updated = sum(1 for p in self._updates if not p.get("compromised"))
        n_skipped = n_total - n_updated
        if success:
            for row in range(n_total):
                self._set_row_install_state(row, "done")
            self._installing_row = None
            self._progress.setValue(n_total)
            self._progress.setFormat("All packages updated  ✓")
            msg = f"<b>{n_updated} package{'s' if n_updated != 1 else ''}</b> updated successfully"
            if n_skipped:
                msg += f" &nbsp;·&nbsp; <b>{n_skipped}</b> compromised — skipped"
            self._hdr.setText(msg)
            self._status.setText("Closing in a moment…")
            subprocess.Popen([
                "notify-send", "Arch Update Complete",
                f"Successfully updated {n_updated} package{'s' if n_updated != 1 else ''}."
                + (f" {n_skipped} compromised skipped." if n_skipped else ""),
                "-i", "system-software-update", "-t", "9000",
            ])
            self.update_succeeded.emit()
            QTimer.singleShot(2000, self.close)
        else:
            self._updating = False
            self._progress.setRange(0, 1)
            self._progress.setValue(0)
            self._progress.setFormat("Update failed or was cancelled")
            # Show last meaningful lines from the captured output
            last = [l for l in output.splitlines() if l.strip()][-3:]
            hint = " · ".join(last) if last else "No output captured"
            self._status.setText(f"Update failed: {hint}")
            self._update_btn.setEnabled(True)
            self._skip_btn.setEnabled(True)

    def showEvent(self, event) -> None:  # type: ignore[override]
        super().showEvent(event)
        # Resize rows after the window is laid out so stretch columns have
        # their final widths — avoids over-tall rows from premature wrapping.
        QTimer.singleShot(0, self._resize_all_rows)

    def _resize_all_rows(self) -> None:
        for i in range(len(self._updates)):
            self.table.resizeRowToContents(i)

    def closeEvent(self, event) -> None:  # type: ignore[override]
        super().closeEvent(event)
        self.closed.emit()


# ── System tray application ────────────────────────────────────────────────────

class TrayApp(QObject):
    _CHECK_INTERVAL_MS = 30 * 60 * 1000   # 30 minutes

    def __init__(self, app: QApplication, icon: QIcon) -> None:
        super().__init__()
        self._app        = app
        self._aur_helper = _find_aur_helper()
        self._updates:     list[dict]                      = []
        self._cached_info: dict[int, tuple[str, str, str]] = {}
        self._window:      UpdateWindow | None             = None
        self._checker:     UpdateChecker | None            = None
        self._fetcher:     InfoFetcher | None              = None

        # ── Tray icon ──────────────────────────────────────────────────────────
        self._tray = QSystemTrayIcon(icon, self)
        self._tray.setToolTip("Arch Update")
        self._tray.activated.connect(self._on_tray_activated)
        self._tray.messageClicked.connect(self._open_window)

        # ── Context menu ───────────────────────────────────────────────────────
        menu = QMenu()
        self._status_act = menu.addAction("Checking for updates…")
        self._status_act.setEnabled(False)
        menu.addSeparator()
        self._show_act = menu.addAction("Show Updates…")
        self._show_act.triggered.connect(self._open_window)
        self._show_act.setEnabled(False)
        self._check_act = menu.addAction("Check Now")
        self._check_act.triggered.connect(self.check_now)
        menu.addSeparator()
        quit_act = menu.addAction("Quit")
        quit_act.triggered.connect(app.quit)
        self._tray.setContextMenu(menu)
        self._tray.show()

        # ── Periodic check timer ───────────────────────────────────────────────
        timer = QTimer(self)
        timer.timeout.connect(self.check_now)
        timer.start(self._CHECK_INTERVAL_MS)

        # Initial check after a short delay (let the desktop settle)
        QTimer.singleShot(2000, self.check_now)

    # ── Check cycle ────────────────────────────────────────────────────────────

    def check_now(self) -> None:
        if self._checker and self._checker.isRunning():
            return
        self._status_act.setText("Checking for updates…")
        self._check_act.setEnabled(False)
        self._checker = UpdateChecker(self._aur_helper)
        self._checker.updates_found.connect(self._on_updates_found)
        self._checker.no_updates.connect(self._on_no_updates)
        self._checker.finished.connect(lambda: self._check_act.setEnabled(True))
        self._checker.start()

    def _on_updates_found(self, updates: list[dict]) -> None:
        self._stop_fetcher()
        self._updates = updates
        self._cached_info = {}
        n = len(updates)
        compromised = [p for p in updates if p.get("compromised")]

        if compromised:
            names = ", ".join(p["name"] for p in compromised)
            self._tray.setToolTip(
                f"⚠️  ARCH UPDATE - SUPPLY CHAIN ATTACK DETECTED  ⚠️\n"
                f"Compromised packages: {names}"
            )
            self._status_act.setText(
                f"⚠️ {len(compromised)} compromised package{'s' if len(compromised) != 1 else ''} blocked"
            )
            self._show_act.setEnabled(True)
            self._tray.showMessage(
                "⚠️ AUR Supply-Chain Attack Detected",
                f"{len(compromised)} package{'s' if len(compromised) != 1 else ''} "
                f"({names}) flagged as compromised. They will be skipped during update.\n"
                f"Safe packages can still be installed.",
                QSystemTrayIcon.MessageIcon.Critical,
                12000,
            )
        else:
            self._tray.setToolTip(f"Arch Update  —  {n} update{'s' if n != 1 else ''} available")
            self._status_act.setText(f"{n} update{'s' if n != 1 else ''} available")
            self._show_act.setEnabled(True)

            self._tray.showMessage(
                "Arch Update",
                f"{n} package{'s' if n != 1 else ''} available — click to update",
                QSystemTrayIcon.MessageIcon.Information,
                6000,
            )

        self._fetcher = InfoFetcher(updates)
        self._fetcher.row_ready.connect(self._on_row_cached)
        self._fetcher.finished.connect(self._on_fetch_done)
        self._fetcher.start()

    def _on_no_updates(self) -> None:
        self._stop_fetcher()
        self._updates = []
        self._cached_info = {}
        self._tray.setToolTip("Arch Update  —  system up to date")
        self._status_act.setText("System is up to date")
        self._show_act.setEnabled(False)

    # ── Fetcher lifecycle ──────────────────────────────────────────────────────

    def _stop_fetcher(self) -> None:
        if self._fetcher is None:
            return
        # Disconnect before interrupting to prevent stale callbacks on cleared data.
        try:
            self._fetcher.row_ready.disconnect(self._on_row_cached)
            self._fetcher.finished.disconnect(self._on_fetch_done)
        except TypeError:
            pass
        if self._fetcher.isRunning():
            self._fetcher.requestInterruption()
            self._fetcher.wait(3000)
        self._fetcher = None

    def _on_row_cached(self, row: int, desc: str, notes: str, date: str) -> None:
        self._cached_info[row] = (desc, notes, date)
        if self._window is not None:
            self._window.on_info_ready(row, desc, notes, date)

    def _on_fetch_done(self) -> None:
        if self._window is not None:
            self._window.on_fetch_done()
        self._fetcher = None

    # ── Tray interaction ───────────────────────────────────────────────────────

    def _on_tray_activated(self, reason: QSystemTrayIcon.ActivationReason) -> None:
        if reason in (
            QSystemTrayIcon.ActivationReason.Trigger,
            QSystemTrayIcon.ActivationReason.DoubleClick,
        ):
            self._open_window()

    def _open_window(self) -> None:
        if not self._updates:
            self._tray.showMessage(
                "Arch Update", "System is up to date.",
                QSystemTrayIcon.MessageIcon.Information, 3000,
            )
            return
        if self._window is not None:
            self._window.raise_()
            self._window.activateWindow()
            return
        self._window = UpdateWindow(self._updates, self._cached_info, self._aur_helper)
        self._window.closed.connect(self._on_window_closed)
        self._window.update_succeeded.connect(self._on_update_succeeded)
        self._window.show()
        self._window.raise_()
        self._window.activateWindow()

    def _on_window_closed(self) -> None:
        self._window = None

    def _on_update_succeeded(self) -> None:
        self._updates = []
        self._cached_info = {}
        self._stop_fetcher()
        self._tray.setToolTip("Arch Update  —  system up to date")
        self._status_act.setText("System is up to date")
        self._show_act.setEnabled(False)
        QTimer.singleShot(5000, self.check_now)


# ── Icon ───────────────────────────────────────────────────────────────────────

def _app_icon() -> QIcon:
    """Render the embedded SVG into a QIcon via QSvgRenderer."""
    renderer = QSvgRenderer(QByteArray(_ICON_SVG))
    pm = QPixmap(64, 64)
    pm.fill(QColor(0, 0, 0, 0))
    painter = QPainter(pm)
    renderer.render(painter, QRectF(0, 0, 64, 64))
    painter.end()
    return QIcon(pm)


# ── Entry point ────────────────────────────────────────────────────────────────

def main() -> None:
    os.environ.setdefault("WAYLAND_DISPLAY", "wayland-0")
    os.environ.setdefault("QT_QPA_PLATFORM", "wayland;xcb")

    app = QApplication(sys.argv)
    app.setApplicationName("arch-update-popup")
    app.setApplicationDisplayName("Arch Update")
    app.setQuitOnLastWindowClosed(False)   # keep alive in tray after window closes

    icon = _app_icon()
    app.setWindowIcon(icon)

    if not QSystemTrayIcon.isSystemTrayAvailable():
        print("No system tray available.", file=sys.stderr)
        sys.exit(1)

    _tray_app = TrayApp(app, icon)  # noqa: F841 — keep reference alive
    sys.exit(app.exec())


if __name__ == "__main__":
    main()

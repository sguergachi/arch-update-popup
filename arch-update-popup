# ── Network helpers ────────────────────────────────────────────────────────────

def _get(url: str, accept: str = "application/json", timeout: int = 6) -> bytes:
    req = urllib.request.Request(url, headers={**_UA, "Accept": accept})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return r.read()


def strip_version(ver: str) -> str:
    """'2:1.2.3-4' → '1.2.3'"""
    ver = re.sub(r"^\d+:", "", ver)   # strip epoch
    ver = re.sub(r"-\d+$", "", ver)   # strip pkgrel
    return ver


_STOP_HEADER_RE = re.compile(
    r"^##\s*(Install|Download|Assets|Windows|macOS|Linux|Building|Usage"
    r"|Note[s]?|Other|Requirements|Checksums|SHA|Verify)",
    re.IGNORECASE | re.MULTILINE,
)

_BOILERPLATE_RE = re.compile(
    r"(?:^for a full|^see (?:the |full )|full changelog|release notes at\b"
    r"|^compare.*https?://)",
    re.IGNORECASE,
)


def _truncate_github_body(body: str) -> str:
    """Remove platform-specific install / asset sections from a GitHub release body."""
    m = _STOP_HEADER_RE.search(body)
    return body[: m.start()].strip() if m else body


def summarize_notes(text: str, max_len: int = 300) -> str:
    """Clean markdown, extract key bullet points, return a one-liner ≤ max_len chars."""
    if not text or not text.strip():
        return ""

    text = re.sub(r"```[\s\S]*?```", " ", text)
    text = re.sub(r"`([^`\n]+)`", r"\1", text)
    text = re.sub(
        r"^\[.*?(?:changelog|release notes?|changes|history)\].*$",
        "",
        text,
        flags=re.IGNORECASE | re.MULTILINE,
    )
    text = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", text)
    text = re.sub(r"\s*\(\[?#\d+\]?\)", "", text)
    text = re.sub(r"\s*\([0-9a-f]{7,40}\)", "", text)
    text = re.sub(r"\s*https?://\S+", "", text)

    lines = text.strip().splitlines()
    intro_parts: list[str] = []
    bullets: list[str] = []

    for line in lines:
        line = line.strip()
        if not line:
            continue
        if re.match(r"^#{1,4}\s", line):
            continue
        if re.match(r"^[A-Za-z][^.!?\n]{0,45}:$", line) and len(line.split()) <= 5:
            continue
        if _BOILERPLATE_RE.match(line):
            continue
        if re.match(r"^[-*•]\s+", line):
            item = re.sub(r"^[-*•]\s+", "", line).strip()
            if len(item) > 12:
                bullets.append(item)
        elif not bullets and len(line) > 12:
            intro_parts.append(line)

    parts: list[str] = []
    intro = " ".join(intro_parts)
    if intro and len(intro) < 160:
        parts.append(intro)
    parts.extend(bullets[:5])

    result = " · ".join(p for p in parts if p).strip(" ·")
    if not result:
        result = " ".join(text.split())

    if len(result) > max_len:
        result = result[: max_len - 1] + "…"
    return result


def extract_version_section(content: str, ver: str) -> str | None:
    """
    Pull the CHANGELOG section for `ver`, handling common header formats.
    Uses a negative lookahead so "25.01" won't match a "25.01.1" header.
    """
    lines = content.splitlines()
    ver_esc = re.escape(ver)
    header_re = re.compile(
        rf"^#{{1,4}}\s.*?[Vv]?{ver_esc}(?![\d.])",
        re.IGNORECASE,
    )

    start = None
    for i, line in enumerate(lines):
        if header_re.search(line):
            start = i + 1
            break
    if start is None:
        return None

    section: list[str] = []
    for line in lines[start:]:
        if re.match(r"^#{1,4}\s", line) and section:
            break
        section.append(line)
        if len(section) > 60:
            break

    return "\n".join(section).strip() or None


# ── GitHub ─────────────────────────────────────────────────────────────────────

def _parse_github_url(url: str) -> tuple[str, str] | None:
    m = re.match(r"https?://github\.com/([^/\s#?]+)/([^/\s#?.]+)", url)
    return (m.group(1), m.group(2).rstrip("/")) if m else None


def _pkgbuild_github_repo(pkg: str) -> tuple[str, str] | None:
    """Read the PKGBUILD from Arch GitLab to find the upstream GitHub repo."""
    try:
        raw = _get(
            f"https://gitlab.archlinux.org/archlinux/packaging/packages/{pkg}/-/raw/main/PKGBUILD",
            accept="text/plain",
            timeout=5,
        ).decode(errors="replace")
        for m in re.finditer(
            r"https://github\.com/([^/\s#?\"'\\)]+)/([^/\s#?.\"'\\)]+?)(?:\.git)?(?:#tag=|/(?:archive|releases)|$|\s)",
            raw,
        ):
            owner, repo = m.group(1), m.group(2)
            if owner.lower() not in ("archlinux",):
                return owner, repo
    except Exception:
        pass
    return None


def _version_matches_release(ver: str, release: dict) -> bool:
    tag = release.get("tag_name", "").lstrip("vV")
    name = (release.get("name") or "").lstrip("vV")
    v_nums = re.findall(r"\d+", ver)
    for cand in (tag, name):
        c_nums = re.findall(r"\d+", cand)
        if v_nums and c_nums and v_nums == c_nums[: len(v_nums)]:
            return True
    return False


def fetch_github_release_notes(owner: str, repo: str, ver: str) -> tuple[str | None, str]:
    """Return (summarized notes, release date YYYY-MM-DD) for `ver`."""
    try:
        data = json.loads(
            _get(
                f"https://api.github.com/repos/{owner}/{repo}/releases?per_page=10",
                accept="application/vnd.github+json",
            )
        )
    except Exception:
        return None, ""

    for rel in data:
        if _version_matches_release(ver, rel):
            date_str = (rel.get("published_at") or "")[:10]
            body = rel.get("body") or ""
            if body.strip():
                cleaned = summarize_notes(_truncate_github_body(body))
                if len(cleaned) > 25:
                    return cleaned, date_str
            return None, date_str

    return None, ""


def fetch_github_changelog_file(owner: str, repo: str, ver: str) -> str | None:
    """Fetch CHANGELOG.md (or similar) and extract the section for `ver`."""
    for branch in ("main", "master", "HEAD"):
        for fname in CHANGELOG_FILENAMES:
            url = f"https://raw.githubusercontent.com/{owner}/{repo}/{branch}/{fname}"
            try:
                content = _get(url, accept="text/plain", timeout=5).decode(errors="replace")
                section = extract_version_section(content, ver)
                if section and len(section) > 40:
                    return summarize_notes(section)
            except urllib.error.HTTPError as e:
                if e.code == 404:
                    continue
                break
            except Exception:
                break
    return None


# ── GitLab ─────────────────────────────────────────────────────────────────────

def fetch_gitlab_release_notes(upstream_url: str, ver: str) -> tuple[str | None, str]:
    for host in GITLAB_HOSTS:
        pat = rf"https?://{re.escape(host)}/([^/\s#?\"']+/[^/\s#?\"'.]+?)(?:\.git)?(?:/|$)"
        m = re.match(pat, upstream_url)
        if not m:
            continue
        project = urllib.request.quote(m.group(1), safe="")
        for tag in (f"v{ver}", ver, f"V{ver}"):
            try:
                data = json.loads(
                    _get(f"https://{host}/api/v4/projects/{project}/releases/{tag}")
                )
                date_str = (data.get("released_at") or "")[:10]
                desc = data.get("description") or ""
                if desc.strip():
                    return summarize_notes(desc), date_str
                return None, date_str
            except Exception:
                continue
    return None, ""


# ── Arch GitLab ────────────────────────────────────────────────────────────────

def fetch_arch_commit_msg(pkg: str) -> tuple[str | None, str]:
    try:
        commits = json.loads(
            _get(
                f"https://gitlab.archlinux.org/api/v4/projects/"
                f"archlinux%2Fpackaging%2Fpackages%2F{pkg}"
                f"/repository/commits?per_page=1"
            )
        )
        if not commits:
            return None, ""
        date_str = (commits[0].get("committed_date") or "")[:10]
        title = commits[0].get("title", "")
        body_lines = commits[0].get("message", "").strip().splitlines()
        extras = [ln.strip() for ln in body_lines[1:] if ln.strip()]
        if extras:
            return (title + " — " + " ".join(extras[:3]))[:200], date_str
        return (title[:120] if title else None), date_str
    except Exception:
        return None, ""


# ── Orchestrator ───────────────────────────────────────────────────────────────

def get_whats_new(
    pkg_name: str, new_ver: str, upstream_url: str, pacman_repo: str
) -> tuple[str, str]:
    """Return (release notes, release date YYYY-MM-DD)."""
    ver = strip_version(new_ver)

    gh = _parse_github_url(upstream_url)
    if not gh and pacman_repo in OFFICIAL_REPOS:
        gh = _pkgbuild_github_repo(pkg_name)

    if gh:
        owner, repo = gh
        # Always fetch releases for the date; prefer CHANGELOG notes when available.
        rel_notes, date = fetch_github_release_notes(owner, repo, ver)
        changelog_notes = fetch_github_changelog_file(owner, repo, ver)
        notes = changelog_notes or rel_notes
        if notes:
            return notes, date

    if any(host in upstream_url for host in GITLAB_HOSTS):
        notes, date = fetch_gitlab_release_notes(upstream_url, ver)
        if notes:
            return notes, date

    if pacman_repo in OFFICIAL_REPOS:
        notes, date = fetch_arch_commit_msg(pkg_name)
        if notes:
            return notes, date

    return f"Version bump: {new_ver}", ""


